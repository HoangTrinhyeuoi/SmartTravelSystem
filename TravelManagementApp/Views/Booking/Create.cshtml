@model CreateBookingViewModel
@{
    ViewData["Title"] = "Create Booking";
}

<h2 class="mb-3">Create New Booking</h2>

<form asp-action="Create" method="post" class="card p-3 shadow-sm">
    <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

    <div class="mb-3">
        <label asp-for="TripID" class="form-label"></label>
        <select asp-for="TripID" class="form-select">
            <option value="">-- Select a trip --</option>
            @foreach (var trip in Model.TripOptions)
            {
                <option value="@trip.ID">@trip.Code - @trip.Destination (@trip.Price.ToString("0.00"))</option>
            }
        </select>
        <span asp-validation-for="TripID" class="text-danger"></span>
    </div>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary">Create</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}