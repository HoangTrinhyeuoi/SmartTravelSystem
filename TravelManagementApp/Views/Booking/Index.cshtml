@model List<Booking>
@{
    ViewData["Title"] = "My Bookings";
    var pendingOnly = (bool)(ViewBag.PendingOnly ?? false);
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">My Bookings</h2>
    <a asp-action="Create" class="btn btn-success">Create Booking</a>
</div>

@if (TempData["Success"] is string successMessage)
{
    <div class="alert alert-success">@successMessage</div>
}

<form method="get" class="mb-3">
    <div class="form-check">
        <input class="form-check-input" type="checkbox" id="pendingOnly" name="pendingOnly" value="true" checked="@pendingOnly" />
        <label class="form-check-label" for="pendingOnly">Show pending bookings only</label>
    </div>
    <button type="submit" class="btn btn-outline-primary btn-sm mt-2">Apply Filter</button>
</form>

<table class="table table-bordered table-striped align-middle">
    <thead class="table-light">
        <tr>
            <th>ID</th>
            <th>Trip Code</th>
            <th>Destination</th>
            <th>Booking Date</th>
            <th>Status</th>
            <th style="width: 180px;">Action</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var booking in Model)
        {
            <tr>
                <td>@booking.ID</td>
                <td>@booking.Trip?.Code</td>
                <td>@booking.Trip?.Destination</td>
                <td>@booking.BookingDate.ToString("yyyy-MM-dd")</td>
                <td>@booking.Status</td>
                <td>
                    <a asp-action="EditStatus" asp-route-id="@booking.ID" class="btn btn-sm btn-outline-primary">Update Status</a>
                </td>
            </tr>
        }
    </tbody>
</table>